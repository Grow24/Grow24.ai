:8080 {
	root * /usr/share/caddy
	@unsafePath {
		path /.git/* /univer/.git/* /node_modules/* /vendor/* /.venv/*
	}
	respond @unsafePath 404

	# Serve full Univer static app from /univer/*
	handle_path /univer/* {
		root * /usr/share/caddy/univer
		try_files {path} {path}/ /index.html
		file_server
	}

	# Legacy / misconfigured builds may request Univer chunks at site root (/chunk-*.js).
	# Those must NOT fall through to the main SPA (which returns HTML and breaks JS).
	@univerRootAssets {
		path_regexp ^/(chunk-.*\.js(\.map)?|lazy-.*\.js(\.map)?|very-lazy-.*\.js(\.map)?|vs/.*|worker\.js|lazy\.js)$
	}
	handle @univerRootAssets {
		root * /usr/share/caddy/univer
		try_files {path} =404
		file_server
	}

	# Main SPA routing at /
	handle {
		try_files {path} /index.html
		file_server
	}

	log {
		output stderr
	}
}
