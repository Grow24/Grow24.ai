:8080 {
	root * /usr/share/caddy
	@unsafePath {
		path /.git/* /univer/.git/* /HBMP_One/.git/* /HBMP_DOCS_PLATFORM/.git/* /HBMP_AgentBot/.git/* /Mxgraph_ReactFlow/.git/* /ivvychainv2/.git/* /OpenStreetMaps/.git/* /Microsoft/.git/* /ImageProcessing/.git/* /Google/.git/* /app_manager/.git/* /hbmp_form_manager/.git/* /mcp_server/.git/* /node_modules/* /vendor/* /.venv/*
	}
	respond @unsafePath 404

	# Normalize /univer -> /univer/ (otherwise catch-all may serve main SPA)
	@univerExact path /univer
	redir @univerExact /univer/ 308

	# Serve real Univer static assets; never rewrite missing assets to index.html.
	@univerAssets path_regexp univer_assets ^/univer/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp)$
	handle @univerAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	# Univer SPA routes under /univer/*
	handle_path /univer/* {
		root * /usr/share/caddy/univer
		try_files {path} {path}/ /index.html
		file_server
	}

	# Legacy / misconfigured builds may request Univer chunks at site root (/chunk-*.js).
	# Those must NOT fall through to the main SPA (which returns HTML and breaks JS).
	@univerRootAssets {
		path_regexp univer_root ^/(chunk-.*\.js(\.map)?|lazy-.*\.js(\.map)?|very-lazy-.*\.js(\.map)?|vs/.*|worker\.js|lazy\.js)$
	}
	handle @univerRootAssets {
		root * /usr/share/caddy/univer
		try_files {path} =404
		file_server
	}

	# --- HBMP_One (Vite base: /HBMP_One/) ---
	@hbmpExact path /HBMP_One
	redir @hbmpExact /HBMP_One/ 308

	# Backward-compat redirect
	@hbmpLegacyExact path /HBMPONE
	redir @hbmpLegacyExact /HBMP_One/ 308

	@hbmpAssets path_regexp hbmp_assets ^/HBMP_One/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @hbmpAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /HBMP_One/* {
		root * /usr/share/caddy/HBMP_One
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- HBMP_DOCS_PLATFORM (Vite base: /HBMP_DOCS_PLATFORM/) ---
	@hbmpDocsExact path /HBMP_DOCS_PLATFORM
	redir @hbmpDocsExact /HBMP_DOCS_PLATFORM/ 308

	@hbmpDocsAssets path_regexp hbmp_docs_assets ^/HBMP_DOCS_PLATFORM/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @hbmpDocsAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /HBMP_DOCS_PLATFORM/* {
		root * /usr/share/caddy/HBMP_DOCS_PLATFORM
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- ivvychainv2 (CRA build under /ivvychainv2/) ---
	@ivvyExact path /ivvychainv2
	redir @ivvyExact /ivvychainv2/ 308

	@ivvyAssets path_regexp ivvy_assets ^/ivvychainv2/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @ivvyAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /ivvychainv2/* {
		root * /usr/share/caddy/ivvychainv2
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- OpenStreetMaps (static files under /OpenStreetMaps/) ---
	@osmExact path /OpenStreetMaps
	redir @osmExact /OpenStreetMaps/ 308

	@osmAssets path_regexp osm_assets ^/OpenStreetMaps/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @osmAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /OpenStreetMaps/* {
		root * /usr/share/caddy/OpenStreetMaps
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- Microsoft (static files under /Microsoft/) ---
	@msExact path /Microsoft
	redir @msExact /Microsoft/ 308

	@msAssets path_regexp ms_assets ^/Microsoft/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @msAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /Microsoft/* {
		root * /usr/share/caddy/Microsoft
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- ImageProcessing (static files under /ImageProcessing/) ---
	@imageProcessingExact path /ImageProcessing
	redir @imageProcessingExact /ImageProcessing/ 308

	@imageProcessingAssets path_regexp image_processing_assets ^/ImageProcessing/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @imageProcessingAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /ImageProcessing/* {
		root * /usr/share/caddy/ImageProcessing
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- Google (Vite base: /Google/) ---
	@googleExact path /Google
	redir @googleExact /Google/ 308

	@googleAssets path_regexp google_assets ^/Google/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @googleAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /Google/* {
		root * /usr/share/caddy/Google
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- app_manager (Vite base: /app_manager/) ---
	@appManagerExact path /app_manager
	redir @appManagerExact /app_manager/ 308

	@appManagerAssets path_regexp app_manager_assets ^/app_manager/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @appManagerAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /app_manager/* {
		root * /usr/share/caddy/app_manager
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- hbmp_form_manager (Vite base: /hbmp_form_manager/) ---
	@hbmpFormManagerExact path /hbmp_form_manager
	redir @hbmpFormManagerExact /hbmp_form_manager/ 308

	@hbmpFormManagerAssets path_regexp hbmp_form_manager_assets ^/hbmp_form_manager/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @hbmpFormManagerAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /hbmp_form_manager/* {
		root * /usr/share/caddy/hbmp_form_manager
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- mcp_server (static page under /mcp_server/) ---
	@mcpServerExact path /mcp_server
	redir @mcpServerExact /mcp_server/ 308

	handle_path /mcp_server/* {
		root * /usr/share/caddy/mcp_server
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- HBMP_AgentBot (if built as static at /HBMP_AgentBot/) ---
	@agentBotExact path /HBMP_AgentBot
	redir @agentBotExact /HBMP_AgentBot/ 308

	# AgentBot backend API and OAuth endpoints.
	# Strip /HBMP_AgentBot so upstream receives /api/* and /oauth/*.
	handle /HBMP_AgentBot/api* {
		uri strip_prefix /HBMP_AgentBot
		reverse_proxy {$AGENTBOT_API_UPSTREAM} {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-For {remote_host}
		}
	}
	handle /HBMP_AgentBot/oauth* {
		uri strip_prefix /HBMP_AgentBot
		reverse_proxy {$AGENTBOT_API_UPSTREAM} {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-For {remote_host}
		}
	}

	@agentBotAssets path_regexp agentbot_assets ^/HBMP_AgentBot/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @agentBotAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /HBMP_AgentBot/* {
		root * /usr/share/caddy/HBMP_AgentBot
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- Mxgraph_ReactFlow (Next.js standalone on 127.0.0.1:5191; Express API optional on MXGRAPH_API_UPSTREAM) ---
	@mxgraphExact path /Mxgraph_ReactFlow
	redir @mxgraphExact /Mxgraph_ReactFlow/ 308

	# Express API (projects/diagrams/exports/flows); strip /Mxgraph_ReactFlow so upstream sees /api/...
	@mxgraphApi path /Mxgraph_ReactFlow/api/projects* /Mxgraph_ReactFlow/api/diagrams* /Mxgraph_ReactFlow/api/exports* /Mxgraph_ReactFlow/api/flows*
	handle @mxgraphApi {
		uri strip_prefix /Mxgraph_ReactFlow
		reverse_proxy {$MXGRAPH_API_UPSTREAM} {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Next.js (pages, RSC, /api/layout, _next static, etc.) — must match MXGRAPH_NEXT_PORT in docker-entrypoint.sh
	handle /Mxgraph_ReactFlow* {
		reverse_proxy 127.0.0.1:5191 {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-For {remote_host}
		}
	}

	# --- Camunda MERN (frontend + API) ---
	@camundaExact path /camunda-bpmn
	redir @camundaExact /camunda-bpmn/ 308

	# API: strip /camunda-bpmn so backend receives /api/*
	handle /camunda-bpmn/api* {
		uri strip_prefix /camunda-bpmn
		reverse_proxy {$CAMUNDA_BACKEND_UPSTREAM:127.0.0.1:4001} {
			header_up Host {host}
		}
	}

	# Frontend: keep /camunda-bpmn prefix for PUBLIC_URL-based routing/assets
	handle /camunda-bpmn* {
		reverse_proxy {$CAMUNDA_FRONTEND_UPSTREAM:127.0.0.1:5196} {
			header_up Host {host}
		}
	}

	# Main SPA routing at /
	handle {
		try_files {path} /index.html
		file_server
	}

	log {
		output stderr
	}
}
