:8080 {
	root * /usr/share/caddy
	@unsafePath {
		path /.git/* /univer/.git/* /HBMPONE/.git/* /HBMP_DOCS_PLATFORM/.git/* /ivvychainv2/.git/* /OpenStreetMaps/.git/* /Microsoft/.git/* /ImageProcessing/.git/* /node_modules/* /vendor/* /.venv/*
	}
	respond @unsafePath 404

	# Normalize /univer -> /univer/ (otherwise catch-all may serve main SPA)
	@univerExact path /univer
	redir @univerExact /univer/ 308

	# Serve real Univer static assets; never rewrite missing assets to index.html.
	@univerAssets path_regexp univer_assets ^/univer/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp)$
	handle @univerAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	# Univer SPA routes under /univer/*
	handle_path /univer/* {
		root * /usr/share/caddy/univer
		try_files {path} {path}/ /index.html
		file_server
	}

	# Legacy / misconfigured builds may request Univer chunks at site root (/chunk-*.js).
	# Those must NOT fall through to the main SPA (which returns HTML and breaks JS).
	@univerRootAssets {
		path_regexp univer_root ^/(chunk-.*\.js(\.map)?|lazy-.*\.js(\.map)?|very-lazy-.*\.js(\.map)?|vs/.*|worker\.js|lazy\.js)$
	}
	handle @univerRootAssets {
		root * /usr/share/caddy/univer
		try_files {path} =404
		file_server
	}

	# --- HBMPONE (Vite base: /HBMPONE/) — same pattern as /univer/ ---
	@hbmpExact path /HBMPONE
	redir @hbmpExact /HBMPONE/ 308

	@hbmpAssets path_regexp hbmp_assets ^/HBMPONE/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @hbmpAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /HBMPONE/* {
		root * /usr/share/caddy/HBMPONE
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- HBMP_DOCS_PLATFORM (Vite base: /HBMP_DOCS_PLATFORM/) ---
	@hbmpDocsExact path /HBMP_DOCS_PLATFORM
	redir @hbmpDocsExact /HBMP_DOCS_PLATFORM/ 308

	@hbmpDocsAssets path_regexp hbmp_docs_assets ^/HBMP_DOCS_PLATFORM/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @hbmpDocsAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /HBMP_DOCS_PLATFORM/* {
		root * /usr/share/caddy/HBMP_DOCS_PLATFORM
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- ivvychainv2 (CRA build under /ivvychainv2/) ---
	@ivvyExact path /ivvychainv2
	redir @ivvyExact /ivvychainv2/ 308

	@ivvyAssets path_regexp ivvy_assets ^/ivvychainv2/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @ivvyAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /ivvychainv2/* {
		root * /usr/share/caddy/ivvychainv2
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- OpenStreetMaps (static files under /OpenStreetMaps/) ---
	@osmExact path /OpenStreetMaps
	redir @osmExact /OpenStreetMaps/ 308

	@osmAssets path_regexp osm_assets ^/OpenStreetMaps/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @osmAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /OpenStreetMaps/* {
		root * /usr/share/caddy/OpenStreetMaps
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- Microsoft (static files under /Microsoft/) ---
	@msExact path /Microsoft
	redir @msExact /Microsoft/ 308

	@msAssets path_regexp ms_assets ^/Microsoft/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @msAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /Microsoft/* {
		root * /usr/share/caddy/Microsoft
		try_files {path} {path}/ /index.html
		file_server
	}

	# --- ImageProcessing (static files under /ImageProcessing/) ---
	@imageProcessingExact path /ImageProcessing
	redir @imageProcessingExact /ImageProcessing/ 308

	@imageProcessingAssets path_regexp image_processing_assets ^/ImageProcessing/.*\.(js|mjs|css|map|json|wasm|ttf|woff|woff2|svg|png|jpg|jpeg|gif|webp|ico)$
	handle @imageProcessingAssets {
		root * /usr/share/caddy
		try_files {path} =404
		file_server
	}

	handle_path /ImageProcessing/* {
		root * /usr/share/caddy/ImageProcessing
		try_files {path} {path}/ /index.html
		file_server
	}

	# Main SPA routing at /
	handle {
		try_files {path} /index.html
		file_server
	}

	log {
		output stderr
	}
}
