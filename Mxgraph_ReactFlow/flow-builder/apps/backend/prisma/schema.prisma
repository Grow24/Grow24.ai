generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FlowMaster {
  id          Int      @id @default(autoincrement())
  name        String
  version     Int      @default(1)
  status      String   @default("draft")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  nodes         NodeMaster[]
  edges         EdgeMaster[]
  variables     VariableMaster[]
  versions      FlowVersionHistory[]
  
  @@map("flows")
}

model NodeMaster {
  id        Int    @id @default(autoincrement())
  flowId    Int
  nodeId    String
  type      String
  label     String
  data      String
  positionX Float
  positionY Float
  
  flow      FlowMaster @relation(fields: [flowId], references: [id], onDelete: Cascade)
  
  @@map("nodes")
}

model EdgeMaster {
  id           Int     @id @default(autoincrement())
  flowId       Int
  edgeId       String
  source       String
  target       String
  sourceHandle String?
  targetHandle String?
  label        String?
  animated     Boolean @default(false)
  
  flow         FlowMaster @relation(fields: [flowId], references: [id], onDelete: Cascade)
  
  @@map("edges")
}

model VariableMaster {
  id           Int    @id @default(autoincrement())
  flowId       Int
  name         String
  type         String
  defaultValue String?
  
  flow         FlowMaster @relation(fields: [flowId], references: [id], onDelete: Cascade)
  
  @@map("variables")
}

model FlowVersionHistory {
  id         Int      @id @default(autoincrement())
  flowId     Int
  version    Int
  jsonBackup String
  author     String?
  createdAt  DateTime @default(now())
  
  flow       FlowMaster @relation(fields: [flowId], references: [id], onDelete: Cascade)
  
  @@map("flow_versions")
}

model TemplateMaster {
  id           String   @id @default(cuid())
  name         String
  category     String
  description  String?
  previewImage String?
  json         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("templates")
}

model SciTemplate {
  id           String   @id @default(cuid())
  name         String
  category     String
  description  String?
  previewImage String?
  json         String
  tags         String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("sci_templates")
}

model DiagramComment {
  id         String   @id @default(cuid())
  flowId     Int
  anchorType String   // "node" | "edge" | "canvas"
  anchorId   String?  // nodeId or edgeId (nullable for canvas)
  content    String
  authorId   String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("diagram_comments")
}

model StickyNote {
  id        String   @id @default(cuid())
  flowId    Int
  x         Float
  y         Float
  width     Float    @default(240)
  height    Float    @default(140)
  color     String   @default("#FFF7D6")
  content   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sticky_notes")
}

model Whiteboard {
  id          String   @id @default(cuid())
  name        String
  description String?
  data        String   // JSON string of Excalidraw elements and appState
  ownerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version     Int      @default(1)
  
  @@map("whiteboards")
}

model MediaAsset {
  id          String   @id @default(cuid())
  kind        String   // "image", "video", "audio", "pdf", "link", "text"
  name        String
  mimeType    String?
  url         String
  thumbnail   String?
  sizeBytes   Int?
  width       Int?
  height      Int?
  durationSec Int?
  meta        String?  // JSON string for additional metadata
  createdAt   DateTime @default(now())
  createdBy   String?
  
  attachments Attachment[]
  
  @@map("media_assets")
}

model Attachment {
  id          String   @id @default(cuid())
  scope       String   // "flowNode", "edge", "whiteboard", "docs", "comments"
  scopeId     String   // nodeId, edgeId, whiteboardId, etc.
  mediaId     String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  
  media       MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  
  @@map("attachments")
}


// Collaboration: basic users and Yjs snapshots
model User {
  id         String   @id @default(cuid())
  name       String
  color      String   @default("#3b82f6")
  avatarUrl  String?
  lastActive DateTime @updatedAt

  @@map("users")
}

model CollabSnapshot {
  id         String   @id @default(cuid())
  docType    String   // flow | whiteboard | docs
  docId      String   // flowId as string, whiteboardId, docId
  version    Int      @default(1)
  snapshot   Bytes    // Yjs binary snapshot/update
  createdAt  DateTime @default(now())
  createdBy  String?

  @@index([docType, docId, createdAt])
  @@map("collab_snapshots")
}


