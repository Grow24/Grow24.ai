{
  "name": "@hbmp/engine",
  "version": "1.0.0",
  "description": "Core engine for React Flow ↔ mxGraph conversion, validation, and layout",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hbmp/shared-types": "workspace:*",
    "@hbmp/ui-tokens": "workspace:*",
    "mxgraph": "^4.2.2",
    "fast-xml-parser": "^4.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist"
  ]
}