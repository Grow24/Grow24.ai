# Microsoft Azure App Registration (copy to .env and fill real values — do not commit secrets)
CLIENT_ID=your-azure-client-id
CLIENT_SECRET=your-azure-client-secret
REDIRECT_URI=http://localhost:5173/auth/callback

# Session Secret (generate a random string for production)
SESSION_SECRET=your-super-secret-random-string-change-this-in-production

# Environment
NODE_ENV=development
PORT=5173
