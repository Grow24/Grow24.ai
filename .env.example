# Frontend environment variables

# Clerk Authentication (Get from https://dashboard.clerk.com/last-active?path=api-keys)
VITE_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Backend API endpoint used by chat/leads.
# Local: http://localhost:3000/api/chat
# Zeabur: https://<your-backend-domain>/api/chat
VITE_API_ENDPOINT=http://localhost:3000/api/chat

# Optional override for send-email endpoint.
# If omitted, frontend derives it from VITE_API_ENDPOINT.
# VITE_SEND_EMAIL_ENDPOINT=https://<your-backend-domain>/api/send-email

# Optional UI settings
VITE_WHATSAPP_NUMBER=+919370239600
VITE_ANALYTICS_ID=your_analytics_id