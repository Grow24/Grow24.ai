# Google OAuth Configuration (Slides)
# Create OAuth 2.0 Client (Web application) in Google Cloud Console
# Authorized redirect URI must match:
#   http://localhost:3002/google/auth/callback

GOOGLE_CLIENT_ID="YOUR_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_CLIENT_SECRET"

# Prefer the Slides-specific redirect var; falls back to GOOGLE_REDIRECT_URI if not set
GOOGLE_REDIRECT_URI_SLIDES=http://localhost:3003/google/oauth/callback

# Server Configuration
PORT=3003

# Optional: Google Drive folder containing template presentations for Slides UI
# Put the folder ID here (the long string in the Drive folder URL)
# When empty, the Templates grid will be hidden and users can paste a URL/ID instead
TEMPLATES_FOLDER_ID=